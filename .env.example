# Copy this file to .env and fill in your actual values.
# NEVER commit .env to GitHub — it contains real secrets.

# Admin
ADMIN_PASSWORD=your_admin_password_here

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Flutterwave (https://dashboard.flutterwave.com/settings/apis)
FLW_SECRET_KEY=FLWSECK_...
FLW_WEBHOOK_SECRET=your_flw_webhook_secret

# Resend email (https://resend.com/api-keys)
RESEND_API_KEY=re_...

# App
APP_URL=https://your-replit-domain.replit.dev
SESSION_SECRET=a_long_random_string_here
