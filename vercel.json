{
  "version": 2,
  "framework": null,
  "installCommand": "echo 'Serving pre-built dist'",
  "buildCommand": "echo 'No build step needed'",
  "outputDirectory": "artifacts/spacex-starlink/dist",
  "rewrites": [
    {
      "source": "/api/keep-alive",
      "destination": "/api/keep-alive"
    },
    {
      "source": "/api/:path*",
      "destination": "https://orbit-starlink-nigeria--edwardlarry067.replit.app/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/keep-alive",
      "schedule": "*/10 * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.orbitfuture.com"
        }
      ],
      "destination": "https://www.orbitfuture.store/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "orbitfuture.com"
        }
      ],
      "destination": "https://www.orbitfuture.store/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ]
}