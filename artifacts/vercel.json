{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/spacex-starlink run build",
  "outputDirectory": "spacex-starlink/dist",
  "framework": null,
  "functions": {
    "api/index.js": {
      "includeFiles": "api-server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ]
}
