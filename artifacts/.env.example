# ── Database ─────────────────────────────────────────────────────────────────
# Neon, Supabase, Railway, or any Postgres connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Paystack ──────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# Default currency for non-geo-detected users (USD or NGN)
PAYSTACK_CURRENCY=USD

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Address that sends confirmation / receipt / admin alert emails
FROM_EMAIL=noreply@orbitfuture.com
# Where admin order alerts are sent
ADMIN_EMAIL=admin@orbitfuture.com

# ── Admin panel ───────────────────────────────────────────────────────────────
ADMIN_PASSWORD=choose-a-strong-password

# ── Stripe (optional — only if enabling Stripe checkout) ─────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── Flutterwave (optional — only if enabling Flutterwave checkout) ────────────
FLW_SECRET_KEY=FLWSECK_xxxxxxxxxxxxxxxxxxxx
FLW_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# ── CORS (optional — add extra allowed origins, comma-separated) ──────────────
# ALLOWED_ORIGINS=https://yourcustomdomain.com
